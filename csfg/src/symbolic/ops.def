//extern fold_constants

simplify_negates {
    "-a*b" --> "-(a*b)"
    "-a/b" --> "-(a/b)"

    "a*-b" --> "-(a*b)"
    "a/-b" --> "-(a/b)"

    "-a*-b" --> "a*b"
    "-a/-b" --> "a/b"
}

simplify_divisions {
    "a*b/b" --> "a"
    "b*a/b" --> "a"
    "-(a*b)/b" --> "-a"
    "-(b*a)/b" --> "-a"

    "a*b/(c*b)" --> "a/c"
    "a*b/(b*c)" --> "a/c"
    "b*a/(c*b)" --> "a/c"
    "b*a/(b*c)" --> "a/c"

    "-(a*b)/(c*b)" --> "-(a/c)"
    "-(a*b)/(b*c)" --> "-(a/c)"
    "-(b*a)/(c*b)" --> "-(a/c)"
    "-(b*a)/(b*c)" --> "-(a/c)"
}

remove_useless_ops {
    //fold_constants
    simplify_negates
    simplify_divisions

    "-(-a)" --> "a"
    "0+a" --> "a"
    "1*a" --> "a"
    "a*1" --> "a"
    "-1*a" --> "a"
    "a*-1" --> "a"
    "-(1*a)" --> "-a"
    "-(a*1)" --> "-a"
    "a^1" --> "a"
    "a^0" --> "1"
    "a*a^-1" --> "1"
    "a^-1^-1" --> "a"
}

//extern expand_constant_exponents

factor {
    "s*a + s*b" --> "s*(a+b)"
    "s*a + b*s" --> "s*(a+b)"
    "a*s + s*b" --> "s*(a+b)"
    "a*s + b*s" --> "s*(a+b)"

    "-(s*a) + -(s*b)" --> "-(s*(a+b))"
    "-(s*a) + -(b*s)" --> "-(s*(a+b))"
    "-(a*s) + -(s*b)" --> "-(s*(a+b))"
    "-(a*s) + -(b*s)" --> "-(s*(a+b))"

    //"a + s^-c" --> "s^-c * (a*s^c + 1)"
    //"a + b*s^-c" --> "s^-c * (a*s^c + b)"

    //"s*s" --> "s^2"
    //"s*s^c" --> "s^(c+1)" [c=const]
    //"s^a * s^b" --> "s^(a+b)"

    //"s+s" --> "2*s"
    //"s+c*s" --> "(c+1)*s" [c=const]
}

expand {
    //    expand_constant_exponents
    "s^(a+b)" --> "s^a * s^b"
    "s*(a+b)" --> "s*a + s*b"
}

simplify {
    expand [ignore]
    remove_useless_ops
    factor [ignore]
    remove_useless_ops
}
